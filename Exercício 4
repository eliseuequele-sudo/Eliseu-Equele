> # Criar um objeto para guardar os resultados dos testes
> resultados <- data.frame(Variavel=variaveis, Estatistica=NA, Valor_p=NA, Normalidade=NA)
> 
> # Laço para cada variável
> for (i in 1:length(variaveis)) {
+   var <- variaveis[i]
+   
+   # Gráfico de probabilidade normal
+   qqnorm(w[[var]], main=paste("QQ-plot -", var), xlab="Quantis teóricos", ylab="Quantis observados")
+   qqline(w[[var]], col="red", lwd=2)
+   
+   # Teste de Shapiro-Wilk
+   teste <- shapiro.test(w[[var]])
+   resultados$Estatistica[i] <- round(teste$statistic, 4)
+   resultados$Valor_p[i] <- round(teste$p.value, 4)
+   
+   # Verificar normalidade (nível de significância de 5%)
+   if (teste$p.value > 0.05) {
+     resultados$Normalidade[i] <- "Sim"
+   } else {
+     resultados$Normalidade[i] <- "Não"
+   }
+ }
