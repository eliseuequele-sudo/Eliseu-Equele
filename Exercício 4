> #12#
> # Lista das variáveis contínuas
> variaveis <- c("Fat", "Density", "Weight", "Height", "Neck", 
+                "Chest", "Abdomen", "Hip", "Thigh", "Knee", 
+                "Ankle", "Biceps", "Forearm", "Wrist", 
+                "peso_kg", "altura_cm")
> 
> # Vetor com as variáveis que apresentaram normalidade (conforme seu resultado)
> normais <- c("Fat", "Density", "Wrist")
> 
> # Criar tabela para armazenar resultados
> resultados_comparacao <- data.frame(
+   Variavel = variaveis,
+   Teste_utilizado = NA,
+   Estatistica = NA,
+   Valor_p = NA,
+   Diferenca_significativa = NA
+ )
> 
> # Laço para aplicar o teste adequado a cada variável
> for (i in 1:length(variaveis)) {
+   var <- variaveis[i]
+   
+   if (var %in% normais) {
+     # Teste t de Student para variáveis com distribuição normal
+     teste <- t.test(w[[var]] ~ w$faixa_etaria)
+     resultados_comparacao$Teste_utilizado[i] <- "Teste t de Student"
+     resultados_comparacao$Estatistica[i] <- round(teste$statistic, 4)
+     resultados_comparacao$Valor_p[i] <- round(teste$p.value, 4)
+   } else {
+     # Teste de Mann-Whitney para variáveis sem distribuição normal
+     teste <- wilcox.test(w[[var]] ~ w$faixa_etaria, exact = FALSE)
+     resultados_comparacao$Teste_utilizado[i] <- "Teste de Mann-Whitney"
+     resultados_comparacao$Estatistica[i] <- round(teste$statistic, 4)
+     resultados_comparacao$Valor_p[i] <- round(teste$p.value, 4)
+   }
+   
+   # Verificar se a diferença é significativa (nível de 5%)
+   if (resultados_comparacao$Valor_p[i] < 0.05) {
+     resultados_comparacao$Diferenca_significativa[i] <- "Sim"
+   } else {
+     resultados_comparacao$Diferenca_significativa[i] <- "Não"
+   }
+ }
